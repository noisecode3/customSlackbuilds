# shellcheck disable=SC2034
cd "$(dirname "$0")"; CWD=$(pwd)

PRGNAM=python3-opt-cycler
VERSION=${VERSION:-0.12.1}
GIT_SHA=${GIT_SHA:-6115d5c55d66cdedb67ec5a0d6b52b6df52fd9d2}
GIT_URL="https://github.com/matplotlib/cycler.git"
BUILD=${BUILD:-1}
TAG=${TAG:-_SBo}
PKGTYPE=${PKGTYPE:-tgz}

# shellcheck disable=SC1091
source helpers/bash_funktions

use_opt_python3

set -e

prepare_git_source "$GIT_URL" "$GIT_SHA"
set_permissions

unshare -n python3 -m build --wheel --no-isolation
python3 -m installer -d "$PKG" dist/*.whl

strip_pkg
install_docs LICENSE

#   |-----handy-ruler------------------------------------------------------|
write_slack_desc "$PKG" "$PRGNAM" \
    "$PRGNAM (composable cycles for Python 3)" \
    "The cycler python module provides a composable cycle class used for" \
    "constructing style-cycles." \
    "" \
    "Homepage: https://github.com/matplotlib/cycler"

cd "$PKG"
/sbin/makepkg -l y -c n "$OUTPUT/$PRGNAM-$VERSION-$ARCH-$BUILD$TAG.$PKGTYPE"
