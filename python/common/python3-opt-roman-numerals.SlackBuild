# shellcheck disable=SC2034
cd "$(dirname "$0")"; CWD=$(pwd)

PRGNAM=python3-opt-roman-numerals
VERSION=${VERSION:-4.1.0}
GIT_SHA=${GIT_SHA:-53c9c4eac63b91728fba3c26329163ee57654d21}
GIT_URL="https://github.com/AA-Turner/roman-numerals.git"
BUILD=${BUILD:-1}
TAG=${TAG:-_SBo}
PKGTYPE=${PKGTYPE:-tgz}

# shellcheck disable=SC1091
source helpers/bash_funktions

use_opt_python3

set -e

prepare_git_source "$GIT_URL" "$GIT_SHA"
set_permissions

cd python

unshare -n python3 -m build --wheel --no-isolation
python3 -m installer -d "$PKG" dist/*.whl

strip_pkg
install_docs LICENSE

#   |-----handy-ruler------------------------------------------------------|
write_slack_desc "$PKG" "$PRGNAM" \
    "$PRGNAM (Roman numerals library)" \
    "A library for manipulating well-formed Roman numerals. Integers" \
    "between 1 and 3,999 (inclusive) are supported." \
    "" \
    "Homepage: https://github.com/AA-Turner/roman-numerals"

cd "$PKG"
/sbin/makepkg -l y -c n "$OUTPUT/$PRGNAM-$VERSION-$ARCH-$BUILD$TAG.$PKGTYPE"
