#!/bin/bash
if [ -z "$ARCH" ]; then
  case "$( uname -m )" in
    i?86) ARCH=i586 ;;
    arm*) ARCH=arm ;;
       *) ARCH=$( uname -m ) ;;
  esac
fi

if [ -n "${PRINT_PACKAGE_NAME}" ]; then
  echo "$PRGNAM-$VERSION-$ARCH-$BUILD$TAG.$PKGTYPE"
  exit 0
fi

TMP=${TMP:-/tmp/SBo}
PKG=$TMP/package-$PRGNAM
OUTPUT=${OUTPUT:-/tmp}

if [ "$ARCH" = "i586" ]; then
  SLKCFLAGS="-O2 -march=i586 -mtune=i686"
  LIBDIRSUFFIX=""
elif [ "$ARCH" = "i686" ]; then
  SLKCFLAGS="-O2 -march=i686 -mtune=i686"
  LIBDIRSUFFIX=""
elif [ "$ARCH" = "x86_64" ]; then
  SLKCFLAGS="-O2 -fPIC"
  LIBDIRSUFFIX="64"
else
  # shellcheck disable=SC2034
  SLKCFLAGS="-O2"
  LIBDIRSUFFIX=""
fi

gzip_info() {
    find "$PKG/usr/info" -type f -exec gzip -9 {} \;
}

gzip_man() {
    find "$PKG/usr/man" -type f -exec gzip -9 {} \;
    while IFS= read -r i; do
        ln -s "$(readlink "$i").gz" "$i.gz"
        rm "$i"
    done < <(find "$PKG/usr/man" -type l)
}

install_docs() {
    local dest="$PKG/usr/doc/$PRGNAM-$VERSION"
    mkdir -p "$dest"
    cp -a "$@" "$dest"
    cat "$CWD/$PRGNAM.SlackBuild" > "$dest/$PRGNAM.SlackBuild"
    find "$PKG/usr/doc/$PRGNAM-$VERSION" -type f -exec chmod 0644 {} \+
}

strip_pkg() {
    find "$PKG" -print0 | xargs -0 file | grep -e "executable" -e "shared object" \
      | grep ELF | cut -f 1 -d : | xargs strip --strip-unneeded 2> /dev/null || true
}

use_opt_rust() {
    export PATH="/opt/rust/bin:$PATH"
    export LD_LIBRARY_PATH="/opt/rust/lib$LIBDIRSUFFIX:$LD_LIBRARY_PATH"
}

use_opt_glib2() {
    export PATH="/opt/glib2/bin:$PATH"
    export LD_LIBRARY_PATH="/opt/glib2/lib64/:$LD_LIBRARY_PATH"
    export PKG_CONFIG_PATH="/opt/glib2/lib64/pkgconfig:$PKG_CONFIG_PATH"
}

use_opt_ninja() {
    export PATH="/opt/ninja/bin/:$PATH"
}

use_opt_python3() {
    export PATH="/opt/python3.12/bin:$PATH"
    export LD_LIBRARY_PATH="/opt/python3.12/lib64:$LD_LIBRARY_PATH"
}

use_opt_cairo() {
    export PATH="/opt/cairo/bin:$PATH"
    export LD_LIBRARY_PATH="/opt/cairo/lib64:$LD_LIBRARY_PATH"
    export PKG_CONFIG_PATH="/opt/cairo/lib64/pkgconfig:$PKG_CONFIG_PATH"
}

use_opt_gcc14() {
    export PATH="/opt/gcc14/bin:$PATH"
    export LD_LIBRARY_PATH="/opt/gcc14/lib64:$LD_LIBRARY_PATH"
}

prepare_directories () {
  rm -rf "$PKG"
  mkdir -p "$TMP" "$PKG" "$OUTPUT"
}

prepare_git_source () {
  local URL=$1
  local REPO="${URL##*/}"
  REPO="${REPO%.git}"
  local GIT_SHA=$2
  prepare_directories
  cd "$TMP" || exit 1
  rm -rf "$REPO"
  git clone "$URL" || exit 1
  cd "$REPO" || exit 1
  git -c advice.detachedHead=false checkout "$GIT_SHA" || exit 1
}

prepare_tar_source () {
  local URL=$1
  local TAR="${URL##*/}"
  local DIR="${TAR%.tar*}"
  local TAR_SHA256=$2
  prepare_directories
  cd "$TMP" || exit 1
  wget -c "$URL" || exit 1
  if ! echo "${TAR_SHA256}  ${TAR}" | sha256sum -c; then
    echo "sha256sum mismatch"
    exit 1
  fi
  rm -rf "$DIR"
  tar xvf "$TAR"
  cd "$DIR" || exit 1
}

set_permissions () {
  chown -R root:root .
  find -L . \
    \( -perm 777 -o -perm 775 -o -perm 750 -o -perm 711 -o -perm 555 \
    -o -perm 511 \) -exec chmod 755 {} \; -o \
    \( -perm 666 -o -perm 664 -o -perm 640 -o -perm 600 -o -perm 444 \
    -o -perm 440 -o -perm 400 \) -exec chmod 644 {} \;
}

write_slack_desc() {
    local pkg="$1"
    local pkgname="$2"
    local summary="$3"
    shift 3
    local desc_lines=("$@")

    local bspace
    bspace=$(printf "%${#pkgname}s")

    mkdir -p "$pkg/install"

    {
        cat <<EOF
# HOW TO EDIT THIS FILE:
# The "handy ruler" below makes it easier to edit a package description.
# Line up the first '|' above the ':' following the base package name, and
# the '|' on the right side marks the last column you can put a character in.
# You must make exactly 11 lines for the formatting to be correct.  It's also
# customary to leave one space after the ':' except on otherwise blank lines.
$bspace|-----handy-ruler------------------------------------------------------|
$pkgname: $summary
$pkgname:
EOF
        local i
        for i in "${desc_lines[@]}"; do
            printf "%s: %s\n" "$pkgname" "$i"
        done

        # Pad to exactly 11 lines (1 summary + 1 blank + N desc lines)
        local filled=$(( 2 + ${#desc_lines[@]} ))
        for (( i=filled; i<11; i++ )); do
            printf "%s:\n" "$pkgname"
        done
    } >> "$pkg/install/slack-desc"
}
