gzip_man () {
  find "$PKG/usr/man" -type f -exec gzip -9 {} \;
  while IFS= read -r i; do
    ln -s "$(readlink "$i").gz" "$i.gz"
    rm "$i"
  done < <(find "$PKG/usr/man" -type l)
}

install_docs () {
  local dest="$PKG/usr/doc/$PRGNAM-$VERSION"
  mkdir -p "$dest"
  if [ "$#" -gt 0 ]; then
    cp -a "$@" "$dest"
  fi
  cat "$CWD/$PRGNAM.SlackBuild" > "$dest/$PRGNAM.SlackBuild"
  find "$PKG/usr/doc/$PRGNAM-$VERSION" -type f -exec chmod 0644 {} \+
}

add_version_info () {
  local ver="$1"
  local dir="$PKG/usr/info"
  [ -d "$dir" ] || return 0
  rm -f "$dir/dir"
  find "$dir" \( -name "*.info" -o -name "*.info.gz" -o -name "*.info-*.gz" \) | while read -r f; do
    case "$f" in
      *.info-*.gz)
        base="${f%.info-*.gz}"
        rest="${f##*.info-}"
        mv "$f" "${base}-${ver}.info-${rest}"
        ;;
      *.info.gz)   mv "$f" "${f%.info.gz}-${ver}.info.gz" ;;
      *.info)      mv "$f" "${f%.info}-${ver}.info" ;;
    esac
  done
}

add_version_man() {
  local ver="$1"
  local dir="$PKG/usr/man"

  [ -d "$dir" ] || return 0

  find "$dir" \( -name '*.[0-9]' -o -name '*.[0-9].gz' \) |
  while read -r f; do
    local gz=

    if [[ $f == *.gz ]]; then
      gz=.gz
      f=${f%.gz}
    fi

    local manext="${f##*.}"
    mv "$f$gz" "${f%."$manext"}-${ver}.${manext}${gz}"
  done
}

strip_pkg () {
  find "$PKG" -print0 | xargs -0 file | grep -e "executable" -e "shared object" \
  | grep ELF | cut -f 1 -d : | xargs strip --strip-unneeded 2> /dev/null || true
}

