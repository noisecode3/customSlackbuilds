#!/bin/bash

if [ -z "$CWD" ]; then
  echo "Error: CWD not set"
  exit 1
fi

if [ -z "$ARCH" ]; then
  case "$( uname -m )" in
    i?86) ARCH=i586 ;;
    arm*) ARCH=arm ;;
       *) ARCH=$( uname -m ) ;;
  esac
fi

if [ -n "${PRINT_PACKAGE_NAME}" ]; then
  echo "$PRGNAM-$VERSION-$ARCH-$BUILD$TAG.$PKGTYPE"
  exit 0
fi

TMP=${TMP:-/tmp/SBo}; mkdir -p "$TMP"
PKG=$TMP/package-$PRGNAM; rm -fr "$PKG"; mkdir -p "$PKG"
OUTPUT=${OUTPUT:-/tmp}; mkdir -p "$OUTPUT"

if [ "$ARCH" = "i586" ]; then
  SLKCFLAGS="-O2 -march=i586 -mtune=i686"
  LIBDIRSUFFIX=""
elif [ "$ARCH" = "i686" ]; then
  SLKCFLAGS="-O2 -march=i686 -mtune=i686"
  LIBDIRSUFFIX=""
elif [ "$ARCH" = "x86_64" ]; then
  SLKCFLAGS="-O2 -fPIC"
  LIBDIRSUFFIX="64"
else
  # shellcheck disable=SC2034
  SLKCFLAGS="-O2"
  LIBDIRSUFFIX=""
fi

# RUSTFLAGS="-C target-cpu=native"
# SLKCFLAGS="-O3 -march=native"
# SLKCFLAGS="-O3 -march=x86-64-v3 -mtune=generic"
# shellcheck disable=SC2034
RUSTFLAGS="-C opt-level=2"

fetch () {
  url="$1"
  file="$2"
  expected="$3"

  if [ -f "$file" ]; then
    sum=$(md5sum "$file" | awk '{print $1}')
    if [ "$sum" = "$expected" ]; then
      return
    fi
  fi

  curl -s -o "$file.tmp" "$url"

  sum=$(md5sum "$file.tmp" | awk '{print $1}')
  if [ "$sum" != "$expected" ]; then
    echo "checksum fail for $file"
    rm -f "$file.tmp"
    exit 1
  fi

  mv "$file.tmp" "$file"
}

get_git_version () {
  VERSION=$(git describe --tags --always | sed s/v// | tr '-' '.' | cut -d'.' -f1-4 \
  | sed -E 's/^([0-9]+\.[0-9]+)\.ROLLING\.([0-9]+)$/\1.\2/')
}

only_C_en_US_locale() {
  find "$1" -mindepth 1 -maxdepth 1 \
    ! -name 'POSIX' \
    ! -name 'C' \
    ! -name 'en_US' \
    ! -name 'C.utf8' \
    ! -name 'en_US.utf8' \
    -exec rm -rf -- {} +
}

